{
  "appId": "com.musicai.app",
  "appName": "music·ai",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#060609",
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "BackgroundRunner": {
      "label": "com.musicai.background",
      "src": "background.js",
      "event": "keepAlive",
      "repeat": true,
      "interval": 15,
      "autoStart": true
    }
  }
}
