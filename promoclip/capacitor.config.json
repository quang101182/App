{
  "appId": "com.promoclip.app",
  "appName": "PromoClip",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#0F0F13",
    "allowMixedContent": true,
    "captureInput": false,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SystemBars": {
      "insetsHandling": "disable",
      "style": "DARK"
    }
  }
}
