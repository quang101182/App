<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".VoiceSnapApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="VoiceSnap"
        android:theme="@style/Theme.VoiceSnap"
        android:supportsRtl="true">

        <!-- MainActivity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.VoiceSnap">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Share Receiver (invisible, receives audio from other apps) -->
        <activity
            android:name=".service.ShareReceiverActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:autoRemoveFromRecents="true"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="video/mp4" />
            </intent-filter>
        </activity>

        <!-- Trampoline Activity (invisible, launches service from foreground context) -->
        <activity
            android:name=".service.TrampolineActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoDisplay"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:autoRemoveFromRecents="true"
            android:taskAffinity="" />

        <!-- Text Viewer (notification tap) -->
        <activity
            android:name=".ui.TextViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.VoiceSnap" />

        <!-- Quick Settings Tile -->
        <service
            android:name=".service.VoiceSnapTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_mic"
            android:label="VoiceSnap"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="true" />
        </service>

        <!-- Foreground Recording Service -->
        <service
            android:name=".service.RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- VoiceSnap IME (Voice Keyboard) -->
        <service
            android:name=".ime.VoiceSnapIME"
            android:label="VoiceSnap Clavier"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Copy text receiver (notification tap) -->
        <receiver
            android:name=".util.CopyReceiver"
            android:exported="false" />

    </application>
</manifest>
