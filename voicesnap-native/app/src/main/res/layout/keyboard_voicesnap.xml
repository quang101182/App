<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#18181B"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:paddingStart="6dp"
    android:paddingEnd="6dp">

    <!-- Clipboard preview banner -->
    <LinearLayout
        android:id="@+id/banner_clipboard"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#2D2D30"
        android:paddingStart="4dp"
        android:paddingEnd="6dp"
        android:visibility="gone">

        <!-- Dismiss button (left) -->
        <FrameLayout
            android:id="@+id/btn_clipboard_dismiss"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="\u2715"
                android:textColor="#71717A"
                android:textSize="14sp" />
        </FrameLayout>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_clipboard"
            android:contentDescription="Coller"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_clipboard_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:clickable="true"
            android:focusable="true"
            android:text="" />

        <TextView
            android:id="@+id/tv_clipboard_paste"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Coller"
            android:textColor="#8B5CF6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="4dp" />
    </LinearLayout>

    <!-- Progress bar (top, visible during processing) -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="#6D28D9"
        android:visibility="gone" />

    <!-- Row 1: Language selectors (tap = popup menu) -->
    <LinearLayout
        android:id="@+id/row_languages"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tv_source_lang"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Auto \u25BE"
            android:textColor="#FAFAFA"
            android:textSize="13sp"
            android:background="@drawable/bg_lang_button"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text=" \u2192 "
            android:textColor="#71717A"
            android:textSize="14sp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <TextView
            android:id="@+id/tv_target_lang"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="EN \u25BE"
            android:textColor="#FAFAFA"
            android:textSize="13sp"
            android:background="@drawable/bg_lang_button"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- Row 2: Status text -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="Appuyez pour parler"
        android:textColor="#71717A"
        android:textSize="12sp"
        android:singleLine="true"
        android:ellipsize="end" />

    <!-- Row 3: Main action buttons (Traduire | Dicter) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Translate button (left) -->
        <FrameLayout
            android:id="@+id/btn_translate"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_button_translate"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_translate"
                    android:contentDescription="Traduire" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Traduire"
                    android:textColor="#FAFAFA"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Dictate button (right, primary) -->
        <FrameLayout
            android:id="@+id/btn_dictate"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_dictate"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/iv_mic_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_mic_large"
                    android:contentDescription="Dicter" />

                <TextView
                    android:id="@+id/tv_dictate_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dicter"
                    android:textColor="#FAFAFA"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Row 4: Tools line — LED ⚙ | Auto-stop | ✨ Rewrite | 🗑 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp">

        <!-- API LEDs (3 dots) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="4dp">

            <View
                android:id="@+id/led_stt"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/led_grey"
                android:layout_marginEnd="3dp" />
            <View
                android:id="@+id/led_llm"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/led_grey"
                android:layout_marginEnd="3dp" />
            <View
                android:id="@+id/led_trd"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/led_grey" />
        </LinearLayout>

        <!-- Settings button (small, after LEDs) -->
        <FrameLayout
            android:id="@+id/btn_settings"
            android:layout_width="32dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_key"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings"
                android:contentDescription="Param\u00e8tres" />
        </FrameLayout>

        <!-- Auto-stop toggle -->
        <TextView
            android:id="@+id/btn_toggle_vad"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:text=" Auto-stop "
            android:textColor="#22C55E"
            android:textSize="11sp"
            android:background="@drawable/bg_toggle"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Theme toggle button -->
        <FrameLayout
            android:id="@+id/btn_theme_toggle"
            android:layout_width="32dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_key"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tv_theme_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="\u25FC"
                android:textColor="#A1A1AA"
                android:textSize="14sp" />
        </FrameLayout>

        <!-- Spacer to push rewrite + trash to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Rewrite button (bigger, tap=rewrite, long-press=mode) -->
        <FrameLayout
            android:id="@+id/btn_rewrite"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minWidth="80dp"
            android:background="@drawable/bg_key_rewrite"
            android:layout_marginEnd="4dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:id="@+id/iv_rewrite_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_rewrite"
                    android:contentDescription="R\u00e9\u00e9crire"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:id="@+id/tv_rewrite_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Propre"
                    android:textColor="#C4B5FD"
                    android:textSize="11sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Clear all button (long-press to delete) -->
        <FrameLayout
            android:id="@+id/btn_clear_all"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_key"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_clear_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_clear_all"
                android:contentDescription="Tout effacer"
                android:alpha="0.6" />
        </FrameLayout>
    </LinearLayout>

    <!-- Row 5: Utility keys -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <!-- Undo -->
        <FrameLayout
            android:id="@+id/key_undo"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="0.9"
            android:background="@drawable/bg_key"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tv_undo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="\u21B6"
                android:textColor="#A1A1AA"
                android:textSize="18sp"
                android:alpha="0.3" />
        </FrameLayout>

        <!-- Redo -->
        <FrameLayout
            android:id="@+id/key_redo"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="0.9"
            android:background="@drawable/bg_key"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tv_redo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="\u21B7"
                android:textColor="#A1A1AA"
                android:textSize="18sp"
                android:alpha="0.3" />
        </FrameLayout>

        <TextView
            android:id="@+id/key_comma"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="0.7"
            android:gravity="center"
            android:text=","
            android:textColor="#FAFAFA"
            android:textSize="16sp"
            android:background="@drawable/bg_key"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/key_period"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="0.7"
            android:gravity="center"
            android:text="."
            android:textColor="#FAFAFA"
            android:textSize="16sp"
            android:background="@drawable/bg_key"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/key_question"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="0.7"
            android:gravity="center"
            android:text="?"
            android:textColor="#FAFAFA"
            android:textSize="16sp"
            android:background="@drawable/bg_key"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Backspace (slightly wider) -->
        <FrameLayout
            android:id="@+id/key_backspace"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1.1"
            android:background="@drawable/bg_key"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_backspace"
                android:contentDescription="Effacer" />
        </FrameLayout>

        <TextView
            android:id="@+id/key_space"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="2.2"
            android:gravity="center"
            android:text="espace"
            android:textColor="#A1A1AA"
            android:textSize="11sp"
            android:background="@drawable/bg_key"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/key_enter"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="\u21B5"
            android:textColor="#FAFAFA"
            android:textSize="18sp"
            android:background="@drawable/bg_key_accent"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
