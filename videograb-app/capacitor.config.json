{
  "appId": "com.videograb.app",
  "appName": "VideoGrab",
  "webDir": "www",
  "server": { "androidScheme": "https" },
  "android": {
    "backgroundColor": "#0a0a0f",
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SystemBars": { "insetsHandling": "disable", "style": "DARK" }
  }
}
